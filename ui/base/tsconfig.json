{
	"compilerOptions": {
		"target": "es2020",
		"module": "es2020",
		"strict": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
    "paths": {
      "@ui/*": [
        "./src/*"
      ]
    }
	},
	"exclude": ["src/**/*.stories.ts"]
}
