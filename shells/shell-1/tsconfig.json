{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "react": [
        "./node_modules/preact/compat/"
      ],
      "react-dom": [
        "./node_modules/preact/compat/"
      ],
      "~/*": [
        "./src/*"
      ],
      "@shared/*": [
        "../../shared/lib/*"
      ],
      "@poc/ui/react/*": [
        "../../ui/react/src/exports/*"
      ],
      "@poc/react-1/components/*": [
        "../../packages/react-1/src/components/*"
      ],
      "angular1/*": [
        "../../packages/angular-1/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
